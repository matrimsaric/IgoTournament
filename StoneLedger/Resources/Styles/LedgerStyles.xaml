<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="StoneLedger.Resources.Styles.LedgerStyles">
    <!-- ===== Colors inspired by StudyPal ===== -->
    <Color x:Key="PrimaryColor">#4A6CF7</Color>
    <!-- Soft blue -->
    <Color x:Key="SecondaryColor">#6C7A92</Color>
    <!-- Muted grey-blue -->
    <Color x:Key="BackgroundColor">#DCE6FF</Color>
    <!-- Light neutral -->
    <Color x:Key="CardColor">#FFFFFF</Color>
    <Color x:Key="ButtonTextColor">#FFFFFF</Color>

    <!-- ===== Typography ===== -->
    <Style x:Key="TitleLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryColor}" />
    </Style>

    <Style x:Key="SubtitleLabelStyle" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="TextColor" Value="{StaticResource SecondaryColor}" />
    </Style>

    <!-- ===== Buttons ===== -->
    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}" />
        <Setter Property="TextColor" Value="{StaticResource ButtonTextColor}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="Margin" Value="0,4" />
    </Style>

    <Style x:Key="CardFrameStyle" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
        <Setter Property="BorderColor" Value="#E0E4EB" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="0,6" />
    </Style>

    <Style x:Key="ListItemTitleStyle" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{StaticResource PrimaryColor}" />
    </Style>

    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Stroke" Value="#E0E4EB" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Background" Value="{StaticResource CardColor}" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="12" />
            </Setter.Value>
        </Setter>
        <Setter Property="Padding" Value="20" />
        <Setter Property="Margin" Value="0,10" />
    </Style>
    
    

</ResourceDictionary>