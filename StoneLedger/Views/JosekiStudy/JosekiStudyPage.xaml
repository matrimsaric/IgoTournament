<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:StoneLedger.Controls"
    x:Class="StoneLedger.Views.JosekiStudy.JosekiStudyPage"
    Title="Joseki Study">

    <Grid ColumnDefinitions="*, 1.2*, *"
    Padding="20"
    ColumnSpacing="20">

        <!-- Player A -->
        <Border Grid.Column="0"
          Style="{StaticResource CardBorderStyle}">
            <!-- LEFT PANEL -->
            <ScrollView Grid.Column="0"
             BackgroundColor="#F0F0F0"
             Padding="10">

                <VerticalStackLayout Spacing="12">

              
                </VerticalStackLayout>

            </ScrollView>
        </Border>

        <!-- Match -->
        <Border Grid.Column="1">
            <Grid  Padding="12"
       HorizontalOptions="Fill"
       VerticalOptions="Fill">

            <controls:GameReplayerControl
         x:Name="GameReplayer"
         BoardTapped="OnBoardTapped"
         Moves="{Binding Moves}"
         MaximumHeightRequest="616"
         MinimumHeightRequest="616"
         MinimumWidthRequest="616"
         MaximumWidthRequest ="616" />

    </Grid>
    </Border>

        <!-- Player B -->
        <Border Grid.Column="2"
        Style="{StaticResource CardBorderStyle}"
        Padding="20">

            <VerticalStackLayout Spacing="20"
                         HorizontalOptions="Center"
                         VerticalOptions="Start">

                <Label Text="Mode"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

                <!-- JOSEKI -->
                <Button x:Name="JosekiButton"
                Text="Joseki"
                WidthRequest="140"
                Clicked="OnJosekiClicked" />

                <!-- VARIATION -->
                <Button x:Name="VariationButton"
                Text="Variation"
                WidthRequest="140"
                Clicked="OnVariationClicked" />

                <!-- CLEAR -->
                <Button x:Name="ClearButton"
                Text="Clear"
                WidthRequest="140"
                Clicked="OnClearAnnotationsClicked" />

            </VerticalStackLayout>

        </Border>

    </Grid>

    
</ContentPage>