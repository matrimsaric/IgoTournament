<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:StoneLedger.Controls"
    x:Class="StoneLedger.Views.JosekiStudy.JosekiStudyPage"
    Title="Joseki Study">

    <Grid ColumnDefinitions="*, 1.2*, *"
    Padding="20"
    ColumnSpacing="20">

        <!-- Player A -->
        <Border Grid.Column="0" x:Name="LeftPanel"
        Style="{StaticResource CardBorderStyle}"
        Padding="0">

            <!-- Inner border that holds the tinted background -->
            <Border BackgroundColor="{Binding PanelBackgroundColour}"
            Padding="20">

                <VerticalStackLayout Spacing="20"
                             HorizontalOptions="Center"
                             VerticalOptions="Start">

                    <!-- Outer ring -->
                    <Border
    StrokeThickness="6"
    Stroke="{Binding ResultRingColour}"
    StrokeShape="RoundRectangle 200"
    WidthRequest="160"
    HeightRequest="160"
    HorizontalOptions="Center"
    VerticalOptions="Center">
                        <!-- Badge -->
                    <Border
                StrokeThickness="0"
                StrokeShape="RoundRectangle 200"
                WidthRequest="140"
                HeightRequest="140"
                BackgroundColor="{Binding BadgeColour}">
                        <Label
                    Text="{Binding BadgeKanji}"
                    FontSize="64"
                    FontAttributes="Bold"
                    TextColor="White"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
                    </Border>
                    </Border>

                    <!-- Title -->
                    <Entry
    Placeholder="Title"
    Text="{Binding Title}"
    FontSize="18"
    BackgroundColor="White"
    HorizontalOptions="Fill"
WidthRequest="{Binding Source={x:Reference LeftPanel}, Path=Width, Converter={StaticResource MultiplyConverter}, ConverterParameter=0.75}" />

                    <!-- Notes -->
                    <ScrollView HeightRequest="250">
                        <Editor
        Placeholder="Notes or description..."
        Text="{Binding Description}"
        FontSize="16"
        BackgroundColor="White"
        VerticalOptions="FillAndExpand"
        AutoSize="TextChanges"
        HorizontalOptions="Fill"
WidthRequest="{Binding Source={x:Reference LeftPanel}, Path=Width, Converter={StaticResource MultiplyConverter}, ConverterParameter=0.75}" />
                    </ScrollView>

                </VerticalStackLayout>

            </Border>
        </Border>


        <!-- Match -->
        <Border Grid.Column="1">
            <Grid  Padding="12"
       HorizontalOptions="Fill"
       VerticalOptions="Fill">

            <controls:GameReplayerControl
         x:Name="GameReplayer"
         BoardTapped="OnBoardTapped"
         Moves="{Binding Moves}"
         MaximumHeightRequest="616"
         MinimumHeightRequest="616"
         MinimumWidthRequest="616"
         MaximumWidthRequest ="616" />

    </Grid>
    </Border>

        <!-- Player B -->
        <Border Grid.Column="2"
        Style="{StaticResource CardBorderStyle}"

        Padding="20">

            <VerticalStackLayout Spacing="20"
                         HorizontalOptions="Center"
                         VerticalOptions="Start">

                <Label Text="Mode"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

                <!-- JOSEKI -->
                <Button x:Name="JosekiButton"
                Text="Joseki"
                WidthRequest="140"
                Clicked="OnJosekiClicked" />

                <!-- VARIATION -->
                <Button x:Name="VariationButton"
                Text="Variation"
                WidthRequest="140"
                Clicked="OnVariationClicked" />

                <!-- CLEAR -->
                <Button x:Name="ClearButton"
                Text="Clear"
                WidthRequest="140"
                Clicked="OnClearAnnotationsClicked" />



                <!-- Mode selector -->
                <Picker
    Title="Study Type"
    ItemsSource="{Binding VariationTypes}"
    SelectedItem="{Binding SelectedStudyMode}" />


                <!-- Branch selector -->
                <Picker
    Title="Branch"
    ItemsSource="{Binding AvailableBranches}"
    SelectedItem="{Binding SelectedBranch}" />
                <HorizontalStackLayout HorizontalOptions="Center">
                    <CheckBox
        IsChecked="{Binding IsSente}" />
                    <Label
        Text="Joseki ends in sente"
        VerticalTextAlignment="Center" />
                </HorizontalStackLayout>


            </VerticalStackLayout>

        </Border>

    </Grid>

    
</ContentPage>