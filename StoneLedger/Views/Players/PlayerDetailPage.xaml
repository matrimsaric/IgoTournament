<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StoneLedger.Views.Players.PlayerDetailPage"
    Title="Player Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Header -->
            <Label Text="Player Details"
                   FontSize="24"
                   FontAttributes="Bold" />

            <!-- Image Preview -->
            <Frame Padding="0"
                   BorderColor="LightGray"
                   CornerRadius="8"
                   WidthRequest="{Binding SelectedImageWidth}"
                   HeightRequest="{Binding SelectedImageHeight}"
                   HorizontalOptions="Center"
                   VerticalOptions="Start"
                   HasShadow="False"
                   BackgroundColor="DimGray">

                <Image Source="{Binding SelectedImageUrl}"
                       Aspect="AspectFit" />
            </Frame>

            <!-- Image Type Picker -->
            <Label Text="Image Type" />
            <Picker ItemsSource="{Binding ImageTypes}"
                    SelectedItem="{Binding SelectedImageType}" />

            <!-- Change Image Button -->
            <Button Text="Change Image"
                    Command="{Binding ChangeImageCommand}" />

            <!-- Name -->
            <Label Text="Name" />
            <Entry Text="{Binding Name}" />

            <!-- Japanese Name -->
            <Label Text="Japanese Name" />
            <Entry Text="{Binding NameJp}" />

            <!-- Rank -->
            <Label Text="Rank" />
            <Entry Text="{Binding Rank}" />

            <!-- Birth Year -->
            <Label Text="Birth Year" />
            <Entry Text="{Binding BirthYear}"
                   Keyboard="Numeric" />

            <!-- Affiliation -->
            <Label Text="Affiliation" />
            <Entry Text="{Binding Affiliation}" />

            <!-- Notes -->
            <Label Text="Notes" />
            <Editor Text="{Binding Notes}"
                    AutoSize="TextChanges"
                    HeightRequest="120" />

            <!-- Archive Toggle -->
            <HorizontalStackLayout Spacing="10">
                <Label Text="Archived" VerticalOptions="Center" />
                <Switch IsToggled="{Binding IsArchived}" />
            </HorizontalStackLayout>

            <!-- Save Button -->
            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="8" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
