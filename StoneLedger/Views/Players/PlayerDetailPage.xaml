<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StoneLedger.Views.Players.PlayerDetailPage"
    BackgroundColor="{StaticResource BackgroundColor}"
    Title="Player Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="24">

            <!-- Image Preview -->
            <Border Stroke="#E0E4EB"
                    StrokeThickness="1"
                    Background="{StaticResource CardColor}"
                    StrokeShape="RoundRectangle 12"
                    Padding="0"
                    HorizontalOptions="Center"
                    WidthRequest="{Binding SelectedImageWidth}"
                    HeightRequest="{Binding SelectedImageHeight}">

                <Image Source="{Binding SelectedImageUrl}"
                       Aspect="AspectFit" />
            </Border>

            <!-- Image Type -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Image Type"
                       Style="{StaticResource FormLabelStyle}" />
                <Picker ItemsSource="{Binding ImageTypes}"
                        SelectedItem="{Binding SelectedImageType}" />
                <Button Text="Change Image"
                        Command="{Binding ChangeImageCommand}" />
            </VerticalStackLayout>

            <!-- Player Info -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="12">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Name" Style="{StaticResource FormLabelStyle}" />
                        <Entry Text="{Binding Name}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Japanese Name" Style="{StaticResource FormLabelStyle}" />
                        <Entry Text="{Binding NameJp}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Rank" Style="{StaticResource FormLabelStyle}" />
                        <Entry Text="{Binding Rank}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Birth Year" Style="{StaticResource FormLabelStyle}" />
                        <Entry Text="{Binding BirthYear}" Keyboard="Numeric" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Affiliation" Style="{StaticResource FormLabelStyle}" />
                        <Entry Text="{Binding Affiliation}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Notes" Style="{StaticResource FormLabelStyle}" />
                        <Editor Text="{Binding Notes}"
                                AutoSize="TextChanges"
                                HeightRequest="120" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <Label Text="Archived" VerticalOptions="Center" />
                        <Switch IsToggled="{Binding IsArchived}" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Save Button -->
            <Button Text="Save"
                    Command="{Binding SaveCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
