<ContentPage
    x:Class="StoneLedger.Views.Players.PlayerListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource BackgroundColor}"
    Title="Players">

    <Grid Padding="20" RowDefinitions="Auto, * , Auto">

        <!-- Header -->
        <Label Text="Players"
               FontSize="28"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Grid.Row="0" />

        <!-- Scrollable List -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding PlayerCollection}"
                        SelectionMode="Single"
                        SelectedItem="{Binding SelectedPlayer, Mode=TwoWay}"
                        Margin="0,20,0,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorderStyle}"
                            Padding="10"
                            Margin="0,6">

                        <Grid ColumnDefinitions="Auto, *"
                              ColumnSpacing="12">

                            <!-- Small Avatar -->
                            <Image Source="{Binding ImageUrl}"
                                   WidthRequest="50"
                                   HeightRequest="50"
                                   Aspect="AspectFill"
                                   VerticalOptions="Center" />

                            <!-- Text Block -->
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2"
                                                 VerticalOptions="Center">

                                <Label Text="{Binding Name}"
                                       FontAttributes="Bold"
                                       FontSize="16" />

                                <Label Text="{Binding Rank}"
                                       FontSize="12"
                                       TextColor="{StaticResource SecondaryColor}" />

                            </VerticalStackLayout>

                        </Grid>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- Add Player Button -->
        <Button Text="Add Player"
                Command="{Binding AddPlayerCommand}"
                Grid.Row="2"
                Margin="0,20,0,0" />

    </Grid>

</ContentPage>
