<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StoneLedger.Views.Players.PlayerContentView">

    <Grid BackgroundColor="#4A90E2" Padding="10">
        <VerticalStackLayout Spacing="6">
            <Label Text="Player Form"
                   FontAttributes="Bold"
                   FontSize="18"
                   TextColor="White" />

            <Label Text="• Wins: 3"
                   TextColor="White" />
            <Label Text="• Losses: 2"
                   TextColor="White" />
            <Label Text="• Streak: W2"
                   TextColor="White" />
        </VerticalStackLayout>
    </Grid>
</ContentView>
