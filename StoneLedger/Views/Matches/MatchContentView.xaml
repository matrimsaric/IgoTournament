<ContentView
    x:Class="StoneLedger.Views.Matches.MatchContentView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid x:Name="RootLayout" Padding="10" BackgroundColor="#7ED321">
        <VerticalStackLayout Spacing="6">
            <Label Text="{Binding Match.Name}" FontAttributes="Bold" FontSize="18" />
            <Label Text="{Binding Match.BoardNumber, StringFormat='Board: {0}'}" />
            <Label Text="{Binding Match.GameDate, StringFormat='Date: {0:d}'}" />
            <Label Text="{Binding Match.Result, StringFormat='Result: {0}'}" />
        </VerticalStackLayout>
    </Grid>

</ContentView>
