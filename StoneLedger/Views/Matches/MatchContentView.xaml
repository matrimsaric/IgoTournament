<ContentView
    x:Class="StoneLedger.Views.Matches.MatchContentView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Grid x:Name="RootLayout"
          Padding="12"
          BackgroundColor="{StaticResource CardColor}"
          ColumnDefinitions="*">

        <VerticalStackLayout Spacing="4">

            <Label Text="{Binding Match.Name}"
                   Style="{StaticResource ListItemTitleStyle}" />

            <Label Text="{Binding Match.BoardNumber, StringFormat='Board: {0}'}"
                   FontSize="14"
                   TextColor="{StaticResource SecondaryColor}" />

            <Label Text="{Binding Match.GameDate, StringFormat='Date: {0:d}'}"
                   FontSize="14"
                   TextColor="{StaticResource SecondaryColor}" />

            <Label Text="{Binding Match.Result, StringFormat='Result: {0}'}"
                   FontSize="14"
                   TextColor="{StaticResource SecondaryColor}" />

        </VerticalStackLayout>

    </Grid>

</ContentView>
