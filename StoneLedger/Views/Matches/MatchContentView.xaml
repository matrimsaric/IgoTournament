<ContentView
    x:Class="StoneLedger.Views.Matches.MatchContentView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:StoneLedger.Controls">

    <Grid x:Name="RootLayout"
          Padding="12"
          BackgroundColor="{StaticResource CardColor}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top: Metadata -->
        <VerticalStackLayout Grid.Row="0" Spacing="4">
            <Label Text="{Binding Match.Name}" Style="{StaticResource ListItemTitleStyle}" />
            <HorizontalStackLayout>
            <Label Text="{Binding Match.BoardNumber, StringFormat='Board: {0}'}"
                   FontSize="14" TextColor="{StaticResource SecondaryColor}" Padding="0,0,0,10" />
            <Label Text="{Binding Match.GameDate, StringFormat='Date: {0:d}'}"
                   FontSize="14" TextColor="{StaticResource SecondaryColor}" Padding="0,0,0,10"/>
            <Label Text="{Binding Match.Result, StringFormat='Result: {0}'}"
                   FontSize="14" TextColor="{StaticResource SecondaryColor}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Bottom: Replayer + Controls -->
        <Grid Grid.Row="1" RowDefinitions="*,Auto" RowSpacing="12">

            <!-- Row 0: Replayer fills all available space -->
            <controls:GameReplayerControl
        x:Name="Replayer"
        Grid.Row="0"
         CurrentMoveIndex="{Binding CurrentMoveIndex}"
        Moves="{Binding ParsedMoves}" />

            <!-- Row 1: Jump controls take only what they need -->
            <HorizontalStackLayout
                    Scale="0.75"
        Grid.Row="1"
        Spacing="10"
        HorizontalOptions="Center">

                <Entry
            x:Name="JumpEntry"
            WidthRequest="80"
            Keyboard="Numeric"
            Placeholder="Move #" />

                <Button
            Text="Jump"
            Clicked="OnJumpClicked" />
            </HorizontalStackLayout>

        </Grid>


    </Grid>
</ContentView>
