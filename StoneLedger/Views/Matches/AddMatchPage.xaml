<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StoneLedger.Views.Matches.AddMatchPage"
    BackgroundColor="{StaticResource BackgroundColor}"
    Title="Add Match">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="24">

            <!-- Form Card -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="16">

                    <!-- Board Number -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Board Number" Style="{StaticResource FormLabelStyle}" />
                        <Entry Text="{Binding BoardNumber}" Keyboard="Numeric" />
                    </VerticalStackLayout>

                    <!-- Player 1 -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Player 1" Style="{StaticResource FormLabelStyle}" />
                        <Picker ItemsSource="{Binding Players}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedPlayer1}" />
                    </VerticalStackLayout>

                    <!-- Player 2 -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Player 2" Style="{StaticResource FormLabelStyle}" />
                        <Picker ItemsSource="{Binding Players}"
                                ItemDisplayBinding="{Binding Name}"
                                SelectedItem="{Binding SelectedPlayer2}" />
                    </VerticalStackLayout>

                    <!-- Winner -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Winner" Style="{StaticResource FormLabelStyle}" />
                        <Picker Title="Winner"
                                ItemsSource="{Binding WinnerOptions}"
                                SelectedItem="{Binding SelectedWinner}" />
                    </VerticalStackLayout>

                    <!-- Result Type -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Result Type" Style="{StaticResource FormLabelStyle}" />
                        <Picker Title="Result Type"
                                ItemsSource="{Binding ResultTypes}"
                                SelectedItem="{Binding SelectedResultType}" />
                    </VerticalStackLayout>

                    <!-- Points -->
                    <VerticalStackLayout Spacing="4"
                                         IsVisible="{Binding IsPointsVisible}">
                        <Label Text="Points" Style="{StaticResource FormLabelStyle}" />
                        <Entry Text="{Binding Points}"
                               Keyboard="Numeric"
                               Placeholder="e.g., 2.5" />
                    </VerticalStackLayout>

                    <!-- Result -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Result" Style="{StaticResource FormLabelStyle}" />
                        <Entry Text="{Binding Result}"
                               Placeholder="e.g., B+R" />
                    </VerticalStackLayout>

                    <!-- SGF Picker -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="SGF File" Style="{StaticResource FormLabelStyle}" />
                        <Button Text="Select SGF File"
                                Command="{Binding PickSgfCommand}" />
                        <Label Text="{Binding SgfFilePath}"
                               FontAttributes="Italic"
                               TextColor="{StaticResource SecondaryColor}" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Save Button -->
            <Button Text="Save"
                    Command="{Binding SaveCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
