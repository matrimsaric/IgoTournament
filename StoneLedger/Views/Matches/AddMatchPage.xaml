<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StoneLedger.Views.Matches.AddMatchPage"
    Title="Add Match">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Add New Match" FontSize="24" FontAttributes="Bold" />

        <Entry Placeholder="Board Number" 
               Keyboard="Numeric"
               Text="{Binding BoardNumber}" />

        <Entry Placeholder="Black Player ID"
               Text="{Binding BlackPlayerId}" />

        <Entry Placeholder="White Player ID"
               Text="{Binding WhitePlayerId}" />

        <Entry Placeholder="Result (e.g., B+R)"
               Text="{Binding Result}" />

        <Entry Placeholder="SGF File Path"
               Text="{Binding SgfPath}" />

        <Button 
            Text="Save"
            Command="{Binding SaveCommand}"
            BackgroundColor="#4CAF50"
            TextColor="White"
            CornerRadius="8" />

    </VerticalStackLayout>

</ContentPage>
