<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StoneLedger.Views.Matches.AddMatchPage"
    Title="Add Match">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="Add New Match" FontSize="24" FontAttributes="Bold" />

        <Entry Placeholder="Board Number" 
               Keyboard="Numeric"
               Text="{Binding BoardNumber}" />

        <Label Text="Player 1" />
        <Picker ItemsSource="{Binding Players}"
            ItemDisplayBinding="{Binding Name}"
            SelectedItem="{Binding SelectedPlayer1}" />

        <Label Text="Player 2" />
        <Picker ItemsSource="{Binding Players}"
            ItemDisplayBinding="{Binding Name}"
            SelectedItem="{Binding SelectedPlayer2}" />

        <Entry Placeholder="Result (e.g., B+R)"
               Text="{Binding Result}" />

        <Button Text="Select SGF File"
        Command="{Binding PickSgfCommand}" />

        <Label Text="{Binding SgfFilePath}" 
       FontAttributes="Italic"
       TextColor="Gray" />


        <Button 
            Text="Save"
            Command="{Binding SaveCommand}"
            BackgroundColor="#4CAF50"
            TextColor="White"
            CornerRadius="8" />

    </VerticalStackLayout>

</ContentPage>
