<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:playerviews="clr-namespace:StoneLedger.Views.Players"
    xmlns:matchviews="clr-namespace:StoneLedger.Views.Matches"
    x:Class="StoneLedger.Views.Matches.MatchDetailPage"
    BackgroundColor="{StaticResource BackgroundColor}">

    <Grid ColumnDefinitions="*, 1.2*, *"
      Padding="20"
      ColumnSpacing="20">

        <!-- Player A -->
        <Border Grid.Column="0"
            Style="{StaticResource CardBorderStyle}">
            <playerviews:PlayerContentView 
            PlayerId="{Binding PlayerAId}" />
        </Border>

        <!-- Match -->
        <Border Grid.Column="1"
            Style="{StaticResource CardBorderStyle}">
            <matchviews:MatchContentView 
            MatchId="{Binding MatchId}" />
        </Border>

        <!-- Player B -->
        <Border Grid.Column="2"
            Style="{StaticResource CardBorderStyle}">
            <playerviews:PlayerContentView 
            PlayerId="{Binding PlayerBId}" />
        </Border>

    </Grid>

</ContentPage>
