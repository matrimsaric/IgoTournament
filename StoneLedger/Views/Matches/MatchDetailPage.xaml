<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:playerviews="clr-namespace:StoneLedger.Views.Players"
    xmlns:matchviews="clr-namespace:StoneLedger.Views.Matches"
    x:Class="StoneLedger.Views.Matches.MatchDetailPage">

    <Grid ColumnDefinitions="*, 1.2*, *"
          Padding="10"
          Style="{StaticResource FormCardStyle}"   BackgroundColor="LightSteelBlue"
          ColumnSpacing="10">

        <playerviews:PlayerContentView Grid.Column="0"
                               PlayerId="{Binding PlayerAId}" />

        <matchviews:MatchContentView Grid.Column="1" />

        <playerviews:PlayerContentView Grid.Column="2"
                               PlayerId="{Binding PlayerBId}" />

    </Grid>
</ContentPage>
