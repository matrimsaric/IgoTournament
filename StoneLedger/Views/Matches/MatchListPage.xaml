<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StoneLedger.Views.Matches.MatchListPage"
    Title="Matches">

    <VerticalStackLayout Padding="10">

        <Button 
            Text="Add New Match"
            Command="{Binding AddMatchCommand}"
            BackgroundColor="#4CAF50"
            TextColor="White"
            CornerRadius="8" />

        <CollectionView 
            ItemsSource="{Binding Matches}"
            SelectionMode="Single"
            SelectedItem="{Binding SelectedMatch, Mode=TwoWay}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame 
                        Padding="10" 
                        Margin="0,5"
                        BorderColor="LightGray"
                        HasShadow="False">

                        <VerticalStackLayout>
                            <Label 
                                Text="{Binding Name}" 
                                FontSize="18" />

                            <!-- Placeholder for future fields -->
                            <!--<Label Text="{Binding Status}" FontSize="14" TextColor="Gray" />-->
                        </VerticalStackLayout>

                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </VerticalStackLayout>

</ContentPage>
