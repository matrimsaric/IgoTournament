<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StoneLedger.Views.Rounds.AddRoundPage"
    Title="Add Round">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Entry Placeholder="Round Name"
           Text="{Binding RoundName}" />

        <Entry Placeholder="Round Number"
           Keyboard="Numeric"
           Text="{Binding RoundNumber}" />

        <DatePicker Date="{Binding RoundDate}" />

        <Editor Placeholder="Notes"
            AutoSize="TextChanges"
            Text="{Binding Notes}" />

        <Button 
            Text="Save"
            Command="{Binding SaveCommand}"
            BackgroundColor="#4CAF50"
            TextColor="White"
            CornerRadius="8" />

    </VerticalStackLayout>

</ContentPage>
