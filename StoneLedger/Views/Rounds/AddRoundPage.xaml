<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="StoneLedger.Views.Rounds.AddRoundPage"
    BackgroundColor="{StaticResource BackgroundColor}"
    Title="Add Round">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="24">

            <!-- Form Card -->
            <Border Style="{StaticResource CardBorderStyle}">
                <VerticalStackLayout Spacing="16">

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Round Name" Style="{StaticResource FormLabelStyle}" />
                        <Entry Text="{Binding RoundName}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Round Number" Style="{StaticResource FormLabelStyle}" />
                        <Entry Text="{Binding RoundNumber}" Keyboard="Numeric" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Round Date" Style="{StaticResource FormLabelStyle}" />
                        <DatePicker Date="{Binding RoundDate}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Notes" Style="{StaticResource FormLabelStyle}" />
                        <Editor Text="{Binding Notes}"
                                AutoSize="TextChanges"
                                HeightRequest="120" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Save Button -->
            <Button Text="Save"
                    Command="{Binding SaveCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
