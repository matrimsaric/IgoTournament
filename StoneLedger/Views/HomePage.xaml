<ContentPage
    x:Class="StoneLedger.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{StaticResource BackgroundColor}"
    Title="Stone Ledger">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <Label Text="Stone Ledger"
                   Style="{StaticResource TitleLabelStyle}" />

            <Label Text="Igo Go tournament archive"
                   Style="{StaticResource SubtitleLabelStyle}" />

            <Button Text="Players"
                    Command="{Binding GoToPlayersCommand}" />

            <Button Text="Matches"
                    Command="{Binding GoToMatchesCommand}" />

            <Button Text="Rounds"
                    Command="{Binding GoToRoundsCommand}" />

            <Button Text="Replay a Game"
                    Command="{Binding GoToReplayCommand}" />

            <Button Text="Tournaments"
                    Command="{Binding GoToTournamentsCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
