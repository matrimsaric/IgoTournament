<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="StoneLedger.Controls.GameReplayerControl">
    <Grid Grid.Row="1"
      Margin="0,12,0,0"
      HorizontalOptions="Center"
      VerticalOptions="Center">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <VerticalStackLayout Grid.Row="1"
                     Spacing="12"
                     HorizontalOptions="Center"
                     VerticalOptions="Center">

            <!-- The board -->
            <GraphicsView
        x:Name="BoardView"
         MinimumWidthRequest="270"
    MinimumHeightRequest="270" >
                <GraphicsView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBoardTapped" />
                </GraphicsView.GestureRecognizers>
            </GraphicsView>

            <!-- The buttons BELOW the board -->
            <HorizontalStackLayout Spacing="20"
                                   HeightRequest="50"
                                       Scale="0.75"
                           HorizontalOptions="Center">

                <Button Text="|◀︎" Command="{Binding FirstMoveCommand}" />
                <Button Text="◀︎" Command="{Binding PreviousMoveCommand}" />
                <Button Text="▶︎" Command="{Binding NextMoveCommand}" />
                <Button Text="▶︎|" Command="{Binding LastMoveCommand}" />
                <Button Text="✎"        WidthRequest="40"        HeightRequest="40"     Clicked="OnToggleAnnotationsPanel" />
                <Button Text="⤢"    Clicked="OnExpandClicked" />
                
            </HorizontalStackLayout>
 
        </VerticalStackLayout>
        <Border x:Name="AnnotationsPanel"
        BackgroundColor="#F0F0F0"
        Stroke="#CCCCCC"
        StrokeThickness="1"
        Padding="10"
        WidthRequest="180"
        VerticalOptions="Start"
        HorizontalOptions="End"
        Margin="0,20,10,0"
        IsVisible="False"
>
            <Border.Shadow>
                <Shadow Brush="Black"
            Opacity="0.4"
            Offset="4,4"
            Radius="6" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="12">

                <Label Text="Annotations"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

                <!-- Tool Selector -->
                <Picker x:Name="AnnotationToolPicker"
                Title="Tool"
                WidthRequest="150"
                SelectedIndexChanged="OnAnnotationToolChanged">
                    <Picker.Items>
                        <x:String>Ring</x:String>
                        <x:String>Label</x:String>
                    </Picker.Items>
                </Picker>

                <!-- Ring Options -->
                <HorizontalStackLayout x:Name="RingOptions" Spacing="6">
                    <Picker x:Name="RingColorPicker"
                    WidthRequest="120">
                        <Picker.Items>
                            <x:String>Green</x:String>
                            <x:String>Blue</x:String>
                        </Picker.Items>
                    </Picker>
                </HorizontalStackLayout>

                <!-- Label Options -->
                <HorizontalStackLayout x:Name="LabelOptions" Spacing="6">
                    <Entry x:Name="LabelEntry"
                   WidthRequest="40"
                   MaxLength="1"
                   Placeholder="A" />
                    <Label Text="Label"
                   VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <!-- Move Numbers -->
                <HorizontalStackLayout Spacing="6">
                    <CheckBox x:Name="MoveNumberToggle"
                      Scale="0.75"
                      CheckedChanged="OnMoveNumberToggleChanged" />
                    <Label Text="Move #s"
                   VerticalTextAlignment="Center" />
                </HorizontalStackLayout>

                <Button Text="Clear"
                WidthRequest="120"
                Clicked="OnClearAnnotationsClicked" />

            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentView>
